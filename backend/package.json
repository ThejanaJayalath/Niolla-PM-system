{
  "name": "niolla-pm-backend",
  "version": "1.0.0",
  "description": "Niolla Project Management System - Backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "npx ts-node-dev --respawn --exit-child --transpile-only src/index.ts",
    "start:mongo": "node scripts/startMongo.js",
    "build": "tsc",
    "start": "node dist/index.js",
    "seed": "npx ts-node scripts/seedAdmin.ts",
    "seed:proposal-template": "npx ts-node scripts/seedProposalTemplate.ts",
    "job:birthdays": "npx ts-node scripts/scanBirthdays.ts",
    "job:anniversaries": "npx ts-node scripts/scanAnniversaries.ts",
    "cleanup:demo-finance": "npx ts-node scripts/cleanupDemoInvoicesAndBilling.ts",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "docx": "^9.5.0",
    "docxtemplater": "^3.68.1",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "googleapis": "^171.4.0",
    "jsonwebtoken": "^9.0.2",
    "libreoffice-convert": "^1.8.1",
    "mongoose": "^8.0.3",
    "multer": "^2.0.2",
    "nodemailer": "^6.9.16",
    "pdf-lib": "^1.17.1",
    "pizzip": "^3.2.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.10.5",
    "@types/nodemailer": "^6.4.17",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
